rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function directoryRequiredFieldsPresent(data) {
      return data.keys().hasAll([
        'label',
        'title',
        'subtitle',
        'url',
        'previewImageUrl',
        'sortOrder',
        'isActive',
        'createdAt',
        'updatedAt',
        'createdBy',
        'updatedBy',
      ]);
    }

    function directoryOnlyAllowedFields(data) {
      return data.keys().hasOnly([
        'label',
        'title',
        'subtitle',
        'url',
        'previewImageUrl',
        'sortOrder',
        'isActive',
        'createdAt',
        'updatedAt',
        'createdBy',
        'updatedBy',
      ]);
    }

    function isValidDirectoryData(data) {
      return directoryRequiredFieldsPresent(data)
        && directoryOnlyAllowedFields(data)
        && data.label is string
        && data.label.size() > 0
        && data.title is string
        && data.title.size() > 0
        && data.subtitle is string
        && data.url is string
        && data.url.size() > 0
        && data.previewImageUrl is string
        && data.sortOrder is int
        && data.isActive is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.createdBy is string
        && data.updatedBy is string;
    }

    function devChecklistRequiredFieldsPresent(data) {
      return data.keys().hasAll([
        'items',
        'lastUpdatedBy',
        'updatedAt',
      ]);
    }

    function devChecklistOnlyAllowedFields(data) {
      return data.keys().hasOnly([
        'items',
        'lastUpdatedBy',
        'updatedAt',
      ]);
    }

    function isValidDevChecklistData(data) {
      return devChecklistRequiredFieldsPresent(data)
        && devChecklistOnlyAllowedFields(data)
        && data.items is list
        && data.lastUpdatedBy is string
        && data.updatedAt is timestamp;
    }

    function beamCharterPublicCreateFieldsOnly(data) {
      return data.keys().hasOnly([
        'institutionSlug',
        'officer1Role',
        'officer1Name',
        'officer1Email',
        'officer1Phone',
        'officer1Enrolled',
        'officer1Credits',
        'officer1StudentId',
        'officer2Role',
        'officer2Name',
        'officer2Email',
        'officer2Phone',
        'officer2Enrolled',
        'officer2Credits',
        'officer2StudentId',
        'officer3Role',
        'officer3Name',
        'officer3Email',
        'officer3Phone',
        'officer3Enrolled',
        'officer3Credits',
        'officer3StudentId',
        'officer4Role',
        'officer4Name',
        'officer4Email',
        'officer4Phone',
        'officer4Enrolled',
        'officer4Credits',
        'officer4StudentId',
        'advisorName',
        'advisorTitle',
        'advisorDepartment',
        'advisorOfficeLocation',
        'advisorEmail',
        'advisorPhone',
        'advisorSupervisorName',
        'advisorSupervisorEmail',
        'divisions',
        'completionPercent',
        'createdAt',
        'updatedAt',
      ]);
    }

    function beamCharterPublicUpdateFieldsOnly(data) {
      return data.diff(resource.data).changedKeys().hasOnly([
        'institutionSlug',
        'officer1Role',
        'officer1Name',
        'officer1Email',
        'officer1Phone',
        'officer1Enrolled',
        'officer1Credits',
        'officer1StudentId',
        'officer2Role',
        'officer2Name',
        'officer2Email',
        'officer2Phone',
        'officer2Enrolled',
        'officer2Credits',
        'officer2StudentId',
        'officer3Role',
        'officer3Name',
        'officer3Email',
        'officer3Phone',
        'officer3Enrolled',
        'officer3Credits',
        'officer3StudentId',
        'officer4Role',
        'officer4Name',
        'officer4Email',
        'officer4Phone',
        'officer4Enrolled',
        'officer4Credits',
        'officer4StudentId',
        'advisorName',
        'advisorTitle',
        'advisorDepartment',
        'advisorOfficeLocation',
        'advisorEmail',
        'advisorPhone',
        'advisorSupervisorName',
        'advisorSupervisorEmail',
        'divisions',
        'completionPercent',
        'updatedAt',
      ]);
    }

    function isValidBeamCharterPublicCreate(slug) {
      return beamCharterPublicCreateFieldsOnly(request.resource.data)
        && request.resource.data.updatedAt is timestamp
        && (!request.resource.data.keys().hasAny(['createdAt']) || request.resource.data.createdAt is timestamp)
        && (!request.resource.data.keys().hasAny(['completionPercent']) || request.resource.data.completionPercent is int)
        && (!request.resource.data.keys().hasAny(['divisions']) || request.resource.data.divisions is list)
        && (!request.resource.data.keys().hasAny(['institutionSlug']) || request.resource.data.institutionSlug == slug);
    }

    function isValidBeamCharterPublicUpdate(slug) {
      return beamCharterPublicUpdateFieldsOnly(request.resource.data)
        && request.resource.data.updatedAt is timestamp
        && (!request.resource.data.keys().hasAny(['completionPercent']) || request.resource.data.completionPercent is int)
        && (!request.resource.data.keys().hasAny(['divisions']) || request.resource.data.divisions is list)
        && (!request.resource.data.keys().hasAny(['institutionSlug']) || request.resource.data.institutionSlug == slug);
    }

    // User-owned profile and onboarding data.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Cross-site website directory entries.
    match /beamWebsiteDirectory/{docId} {
      allow read: if true;
      // Development mode: temporarily open writes to unblock dashboard iteration.
      // Tighten this back to admin-only before production launch.
      allow create, update: if isValidDirectoryData(request.resource.data);
      allow delete: if true;
    }

    match /devChecklists/{docId} {
      allow read: if true;
      allow create, update: if isValidDevChecklistData(request.resource.data);
      allow delete: if true;
    }

    match /nodes/{docId} {
      allow read: if resource.data.publiclyVisible == true || isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /beamSubstrate/{docId} {
      allow read, create, update, delete: if isSignedIn();
    }

    // beamCharters
    // Public reads are intentional so the shareable intake link can show live completion state.
    // Unauthenticated intake writes stay limited to participant-safe fields; tighten further if abuse appears.
    match /beamCharters/{slug} {
      allow read: if true;
      allow create: if isSignedIn() || isValidBeamCharterPublicCreate(slug);
      allow update: if isSignedIn() || isValidBeamCharterPublicUpdate(slug);
      allow delete: if isSignedIn();
    }

    match /intake/{docId} {
      allow create: if request.resource.data.keys().hasAll([
          'orgName',
          'orgUrl',
          'nodeId',
          'sectors',
          'contactName',
          'contactEmail',
          'needs',
          'offers',
          'description',
          'submittedAt',
          'status'
        ]);
      allow read, update, delete: if isSignedIn();
    }

    // BEAM game engine collections (Phase 1).
    // Development mode: keep reads open and writes permissive for active admin iteration.
    // Tighten this to admin-only before production launch.
    match /beamRegions/{docId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /beamProjects/{docId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /beamActions/{docId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /beamTasks/{docId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /beamAssets/{docId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // Canonical participant identity and membership layer.
    match /organizations/{docId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /cohorts/{docId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /participantProfiles/{docId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /organizationMemberships/{docId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /cohortMemberships/{docId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /participantSourceAttribution/{docId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /ragAllowlist/{docId} {
      allow get: if isSignedIn() && resource.data.email == request.auth.token.email;
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }
  }
}
